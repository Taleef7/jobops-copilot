{
  "name": "@jobops/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "db:init": "tsx scripts/db-init.ts",
    "test": "node scripts/run-tests.mjs",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.28.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0",
    "tsc-alias": "^1.8.17",
    "typescript-eslint": "^8.0.0"
  }
}
